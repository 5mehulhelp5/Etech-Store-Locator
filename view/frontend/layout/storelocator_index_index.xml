<?xml version="1.0"?>
<page layout="1column"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!-- Precompiled, .ks-locator-scoped Tailwind utilities for the map/search UI,
             so it renders on any theme (Hyvä's Tailwind is purged; no Play CDN). -->
        <css src="Etechflow_StoreLocator::css/locator-tailwind.css"/>
    </head>
    <body>
        <referenceBlock name="page.main.title" remove="true"/>
        <referenceContainer name="content">
            <block class="Etechflow\StoreLocator\Block\Frontend\Locator"
                   name="etechflow.storelocator.locator"
                   template="Etechflow_StoreLocator::locator.phtml"/>
        </referenceContainer>
    </body>
</page>
