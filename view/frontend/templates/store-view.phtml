$store   = $block->getStore();
$name    = (string) $store->getName();
$tagline = (string) $store->getTagline();
$street  = (string) $store->getStreet();
$city    = (string) $store->getCity();
$county  = (string) $store->getCounty();
$post    = (string) $store->getPostcode();
$phone   = (string) $store->getPhone();
$email   = (string) $store->getEmail();
$hours   = (string) $store->getHours();
$lat     = $store->getLat() !== null && $store->getLat() !== '' ? (float) $store->getLat() : null;
$lng     = $store->getLng() !== null && $store->getLng() !== '' ? (float) $store->getLng() : null;
$hasGeo  = $lat !== null && $lng !== null;
$address = implode(', ', array_filter([$street, $city, $county, $post]));
