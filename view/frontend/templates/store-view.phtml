<script>
(function () {
    var LAT = <?= /* @noEscape */ json_encode($lat) ?>,
        LNG = <?= /* @noEscape */ json_encode($lng) ?>,
        NAME = <?= /* @noEscape */ json_encode($name) ?>;

    // Wait for the Leaflet CDN, then wait for the container to have a real size
    // before init — never measure a 0-size element (avoids the grey-tile bug).
    function whenReady(cb) {
        if (window.L) { cb(); return; }
        var t = setInterval(function () { if (window.L) { clearInterval(t); cb(); } }, 80);
        setTimeout(function () { clearInterval(t); }, 8000);
    }
    function whenSized(el, cb) {
        var t = setInterval(function () {
            if (el.offsetWidth > 0 && el.offsetHeight > 0) { clearInterval(t); cb(); }
        }, 100);
        setTimeout(function () { clearInterval(t); }, 8000);
    }
    function boot() {
        var el = document.getElementById('ksd-map');
        if (!el) { return; }
        whenReady(function () { whenSized(el, function () {
            var map = L.map('ksd-map', { scrollWheelZoom: false }).setView([LAT, LNG], 14);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19, attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);
            L.circleMarker([LAT, LNG], {
                radius: 9, fillColor: '#C41818', fillOpacity: 1, color: '#ffffff', weight: 2
            }).addTo(map).bindPopup(NAME).openPopup();
            [100, 300, 600, 1200].forEach(function (ms) { setTimeout(function () { map.invalidateSize(); }, ms); });
            window.addEventListener('resize', function () { map.invalidateSize(); });
        }); });
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', boot);
    } else {
        boot();
    }
})();
</script>
