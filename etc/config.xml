<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <etechflow_storelocator>
            <license>
                <production_environment>1</production_environment>
                <license_key/>
                <issued_key/>
                <issued_at>0</issued_at>
                <ip_blocked>0</ip_blocked>
                <!-- CRITICAL: must point to the live licensing service (not portal.etechflow.com) -->
                <portal_url>https://license-service.etechflow.com/license/validate</portal_url>
            </license>
            <general>
                <google_maps_api_key></google_maps_api_key>
                <default_radius>10</default_radius>
            </general>
        </etechflow_storelocator>
    </default>
</config>
