<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="etechflow" translate="label" sortOrder="300">
            <label>Etechflow</label>
        </tab>
        <section id="etechflow_storelocator" translate="label" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Store Locator</label>
            <tab>etechflow</tab>
            <resource>Etechflow_StoreLocator::stores</resource>
            <group id="license" translate="label" sortOrder="5" showInDefault="1" showInWebsite="0" showInStore="0">
                <label>License</label>
                <field id="license_key" translate="label comment" sortOrder="10" type="text" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Key</label>
                    <comment><![CDATA[Paste your eTechFlow SP-XXXX subscription key (generated automatically after checkout) OR a per-module HMAC key. Leave blank if using a Bundle License Key. Get one at <a href="https://etechflow.com" target="_blank">etechflow.com</a>.]]></comment>
                </field>
                <field id="issued_key" translate="label comment" sortOrder="20" type="obscure" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Issued Key (auto)</label>
                    <comment><![CDATA[Set automatically on first successful validation. Used to restore the key after an IP-block event. Do not edit.]]></comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
                <field id="portal_url" translate="label comment" sortOrder="25" type="text" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Portal URL</label>
                    <comment><![CDATA[eTechFlow licensing portal endpoint. Update only if your portal URL changes.]]></comment>
                </field>
                <field id="bundle_license_key" translate="label comment" sortOrder="30" type="obscure" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Bundle License Key</label>
                    <comment><![CDATA[Shared key that activates every eTechFlow module on this host. Set EITHER this OR the per-module key above.]]></comment>
                    <config_path>etechflow_bundle/license/license_key</config_path>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
            </group>
            <group id="general" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General Settings</label>
                <field id="brand_name" translate="label comment" type="text" sortOrder="5" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Brand Name</label>
                    <comment>Shown in the storefront copy, e.g. "Visit your local &lt;Brand&gt; store". Leave blank to use the configured Store Name.</comment>
                </field>
                <field id="google_maps_api_key" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Google Maps API Key</label>
                    <comment>Optional. The map uses free Leaflet + OpenStreetMap and does not require a Google key.</comment>
                </field>
                <field id="default_radius" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Default Search Radius (km)</label>
                    <comment>Default radius in kilometres used for the store finder search.</comment>
                </field>
            </group>
        </section>
    </system>
</config>
